root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

# Add a repository-wide editor configuration to ensure consistent formatting.
# This is a best practice for maintaining a consistent coding style across the repository.


